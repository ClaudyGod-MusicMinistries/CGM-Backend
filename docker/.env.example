# ─────────────────────────────────────────────────────────────────────────────
# ClaudyGod Production Environment Variables
# Copy: cp .env.example .env  →  fill in every CHANGE_ME value.
# NEVER commit docker/.env to source control — it contains secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Domains ───────────────────────────────────────────────────────────────────
DOMAIN=claudygod.org
API_DOMAIN=api.claudygod.org
ACME_EMAIL=peter4tech@gmail.com

# ── GHCR Image references ────────────────────────────────────────────────────
# Set TAG to a specific sha-xxxxxx for pinned/rollback deploys,
# or keep "latest" for rolling updates (CI always pushes :latest on main).
IMAGE_API=ghcr.io/claudygod-musicministries/cgm-api
IMAGE_WEB=ghcr.io/claudygod-musicministries/cgm-web
TAG=latest

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# For Supabase managed DB, set DB_HOST to your Supabase pooler host and
# leave POSTGRES_DB / POSTGRES_USER / POSTGRES_PASSWORD matching your project.
DB_HOST=db
POSTGRES_DB=claudygod
POSTGRES_USER=cgm
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME

# ── JWT ───────────────────────────────────────────────────────────────────────
# Minimum 32 bytes. Generate: openssl rand -base64 48
JWT_KEY=CHANGE_ME

# ── AES-256 Encryption ────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=CHANGE_ME

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=noreply@claudygod.org
EMAIL_SMTP_PASSWORD=CHANGE_ME
EMAIL_ADMIN=admin@claudygod.org

# ── Anthropic (Claude AI — optional) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
