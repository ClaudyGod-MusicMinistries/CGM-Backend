# ============================================================
# ClaudyGod Backend — Environment Variables
# Copy this file to docker/.env and fill in real values.
# NEVER commit docker/.env to source control.
# ============================================================

# Domain config
DOMAIN=claudygod.org
API_DOMAIN=api.claudygod.org
ACME_EMAIL=admin@claudygod.org

# Database — Supabase pooled connection
# Format: Host=db.REF.supabase.co;Port=5432;Database=postgres;Username=postgres.REF;Password=SECRET;SSL Mode=Require;Trust Server Certificate=true
ConnectionStrings__DefaultConnection=Host=db.REPLACE_REF.supabase.co;Port=5432;Database=postgres;Username=postgres.REPLACE_REF;Password=REPLACE_PASSWORD;SSL Mode=Require;Trust Server Certificate=true;Pooling=true;Minimum Pool Size=2;Maximum Pool Size=20

# JWT — must be at least 32 random characters
Jwt__Key=REPLACE_WITH_32_PLUS_RANDOM_CHARACTERS_HERE

# Email (Gmail App Password — enable 2FA then generate app password)
Email__SmtpHost=smtp.gmail.com
Email__SmtpPort=587
Email__SmtpUsername=claudygodmusic@gmail.com
Email__SmtpPassword=REPLACE_WITH_GMAIL_APP_PASSWORD
Email__AdminEmail=admin@claudygod.org

# Encryption key — exactly 32 characters
Encryption__Key=REPLACE_WITH_EXACTLY_32_CHAR_KEY!
