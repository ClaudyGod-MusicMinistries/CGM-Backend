# ─────────────────────────────────────────────────────────────────────────────
# ClaudyGod VPS — Environment Variables
#
# Copy:  cp .env.example .env
# Fill:  replace every CHANGE_ME with real values
# Never: commit docker/.env — it contains secrets
# ─────────────────────────────────────────────────────────────────────────────

# ── Domains ───────────────────────────────────────────────────────────────────
DOMAIN=claudygod.org
API_DOMAIN=api.claudygod.org
ACME_EMAIL=peter4tech@gmail.com

# ── GHCR image references ─────────────────────────────────────────────────────
# These are updated automatically by each CI/CD deploy workflow.
# For manual pin: set TAG to a specific sha-xxxxxxx.
IMAGE_API=ghcr.io/claudygod-musicministries/cgm-api
IMAGE_WEB=ghcr.io/claudygod-musicministries/cgm-web
TAG=latest

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# DB_HOST=db  →  local Docker container (default)
# DB_HOST=db.xxx.supabase.co  →  Supabase managed DB
DB_HOST=db
POSTGRES_DB=claudygod
POSTGRES_USER=cgm
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME

# ── JWT ───────────────────────────────────────────────────────────────────────
# Minimum 32 bytes when UTF-8 encoded.
# Generate: openssl rand -base64 48
JWT_KEY=CHANGE_ME

# ── AES-256 encryption ────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=CHANGE_ME

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=noreply@claudygod.org
EMAIL_SMTP_PASSWORD=CHANGE_ME
EMAIL_ADMIN=admin@claudygod.org

# ── Paystack (optional — payment features disabled if not set) ─────────────────
# Server-side secret key. NEVER put in frontend or commit to git.
# NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY is a GitHub Actions secret baked into the image.
PAYSTACK_SECRET_KEY=

# ── Anthropic Claude AI (optional — AI chat disabled if not set) ──────────────
ANTHROPIC_API_KEY=
