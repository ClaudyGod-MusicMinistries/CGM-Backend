{
  "Email": {
    "EnableSsl": true,
    "UsePostfix": false,
    "PostfixHost": "postfix",
    "PostfixPort": 25
  },
  "FileStorage": {
    "LocalBasePath": "/app/uploads",
    "BaseUrl": "/uploads",
    "MaxFileSizeMb": 50
  },
  "Redis": {
    "InstanceName": "claudygod:"
  },
  "RateLimit": {
    "PermitLimit": 200,
    "WindowSeconds": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Error",
      "Microsoft.EntityFrameworkCore.Database.Command": "Error"
    }
  },
  "AllowedHosts": "*"
}
