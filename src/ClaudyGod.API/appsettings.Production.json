{
  "Email": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "EnableSsl": true,
    "UsePostfix": false
  },
  "FileStorage": {
    "LocalBasePath": "/app/uploads",
    "BaseUrl": "/uploads",
    "MaxFileSizeMb": 50
  },
  "Redis": {
    "ConnectionString": "redis:6379",
    "InstanceName": "claudygod:"
  },
  "RateLimit": {
    "PermitLimit": 200,
    "WindowSeconds": 60
  },
  "Jwt": {
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Cors": {
    "Origins": [
      "https://claudygod.org",
      "https://www.claudygod.org",
      "https://admin.claudygod.org"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Error",
      "Microsoft.EntityFrameworkCore": "Error",
      "Microsoft.EntityFrameworkCore.Database.Command": "Error"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Error",
        "System": "Error"
      }
    }
  },
  "AllowedHosts": "*"
}
